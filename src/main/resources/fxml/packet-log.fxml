<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hconex.ui.controllers.PacketLogController"
      spacing="8" styleClass="panel">

    <padding><Insets top="8" right="8" bottom="8" left="8" /></padding>

    <!-- ===== Filter bar ===== -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Filtros:" />
        <CheckBox fx:id="chkShowIncoming" text="Entrantes (S→C)" selected="true" />
        <CheckBox fx:id="chkShowOutgoing" text="Salientes (C→S)" selected="true" />
        <Separator orientation="VERTICAL" />
        <Label text="Opcode:" />
        <TextField fx:id="txtHeaderFilter" prefWidth="100"
                   promptText="ej. 0x0A1B" />
        <Button fx:id="btnRefresh" text="Actualizar" onAction="#onRefresh" />
        <Button fx:id="btnClear" text="Limpiar" onAction="#onClear" />
    </HBox>

    <!-- ===== Packet table ===== -->
    <TableView fx:id="logTable" styleClass="packet-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTime" text="Hora" prefWidth="100" />
            <TableColumn fx:id="colDirection" text="Dirección" prefWidth="90" />
            <TableColumn fx:id="colHeader" text="Opcode" prefWidth="80" />
            <TableColumn fx:id="colLength" text="Bytes" prefWidth="70" />
            <TableColumn fx:id="colHex" text="Hex" prefWidth="460" />
        </columns>
        <placeholder>
            <Label text="No hay paquetes en el log." />
        </placeholder>
    </TableView>

</VBox>
