<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hconex.ui.controllers.ConnectionController"
      spacing="12" styleClass="panel settings-panel"
      maxWidth="500">

    <padding><Insets top="16" right="16" bottom="16" left="16" /></padding>

    <Label text="Configuración de Conexión"
           styleClass="settings-title" />

    <!-- ===== Remote server ===== -->
    <TitledPane text="Servidor Remoto (habbo.es)" collapsible="false">
        <GridPane hgap="10" vgap="8">
            <padding><Insets top="8" right="8" bottom="8" left="8" /></padding>

            <Label text="Host:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtRemoteHost"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"
                       prefWidth="220" />

            <Label text="Puerto:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="txtRemotePort"
                       GridPane.columnIndex="1" GridPane.rowIndex="1"
                       prefWidth="100" />
        </GridPane>
    </TitledPane>

    <!-- ===== Local proxy ===== -->
    <TitledPane text="Proxy Local" collapsible="false">
        <GridPane hgap="10" vgap="8">
            <padding><Insets top="8" right="8" bottom="8" left="8" /></padding>

            <Label text="Puerto local:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtLocalPort"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"
                       prefWidth="100" />
        </GridPane>
    </TitledPane>

    <!-- ===== Action buttons ===== -->
    <HBox spacing="8">
        <Button text="Guardar" onAction="#onSave" styleClass="btn-primary" />
        <Button text="Restablecer" onAction="#onResetDefaults" />
    </HBox>

    <Label fx:id="lblConnectionInfo" text="" styleClass="info-label"
           wrapText="true" />

</VBox>
